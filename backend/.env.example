# MongoDB
# Kimlik doğrulama YOKSA:
#   MONGO_URI=mongodb://localhost:27017
# Kullanıcı adı/şifre VARSA (örnek):
#   MONGO_URI=mongodb://kullanici_adi:sifre@localhost:27017/kocaeli_haber?authSource=admin
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=kocaeli_haber

# Google Maps API Key: https://console.cloud.google.com/ → API'ler → Kimlik Bilgileri → API anahtarı oluştur
# Etkinleştir: Maps JavaScript API + Geocoding API
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Geocoding provider: "google" or "nominatim"
GEOCODING_PROVIDER=nominatim

# Flask
FLASK_PORT=5001
FLASK_DEBUG=True
